---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="A quiet portfolio for research, writing, and work in progress.">
  <main>
    <section class="hero wrap">
      <div class="hero-copy reveal">
        <p class="eyebrow">Researcher &middot; Builder &middot; Note-taker</p>
        <h1>I make difficult ideas <em>easier to see.</em></h1>
        <p class="hero-lede">A calm corner of the internet for field notes, careful experiments, and things I have learned by building.</p>
        <div class="hero-actions">
          <a class="button button-dark" href="/blog/">Read the notes <span aria-hidden="true">-&gt;</span></a>
          <a class="text-link" href="/portfolio/">Explore selected work <span aria-hidden="true">-&gt;</span></a>
        </div>
      </div>

      <aside class="desk-card reveal delay-1" aria-label="Currently exploring">
        <div class="desk-card-top"><span>DESK NOTE / 01</span><span class="status-dot">LIVE</span></div>
        <p class="handwritten">&ldquo;Understanding begins when we give an idea somewhere to land.&rdquo;</p>
        <div class="latency-note" role="img" aria-label="Jeff Dean magic numbers comparing computer latency to human time">
          <div class="latency-note-title">Jeff Dean&rsquo;s magic numbers</div>
          <div class="latency-row">
            <span>L1 cache reference</span>
            <strong>~0.5-1 ns</strong>
            <em>1 second</em>
          </div>
          <div class="latency-row">
            <span>Mutex lock/unlock</span>
            <strong>~25 ns</strong>
            <em>25 seconds</em>
          </div>
          <div class="latency-row">
            <span>CA -> Netherlands -> CA</span>
            <strong>~150,000,000 ns</strong>
            <em>5 years</em>
          </div>
        </div>
        <div class="desk-tags"><span>Systems</span><span>Latency</span><span>Scale</span></div>
      </aside>
    </section>

    <section class="signal-strip" aria-label="Current status">
      <div class="wrap signal-inner">
        <p><span class="signal-label">NOW</span> Exploring how visual notes improve technical understanding.</p>
        <p class="signal-meta">Singapore &middot; 1&deg;17'N</p>
      </div>
    </section>

    <section class="wrap section-grid">
      <div>
        <p class="eyebrow">From the notebook</p>
        <h2>Recent thinking</h2>
      </div>
      <div class="feature-list">
        <a class="feature-row" href="/blog/ai-inference/">
          <span class="feature-num">01</span><span><strong>AI Inference: What happens after the model is trained?</strong><small>Foundational &middot; 10 min read</small></span><span class="arrow">-&gt;</span>
        </a>
        <a class="feature-row" href="/blog/model-evaluation/">
          <span class="feature-num">02</span><span><strong>Evaluating AI without fooling ourselves</strong><small>Systems &middot; 8 min read</small></span><span class="arrow">-&gt;</span>
        </a>
        <a class="feature-row" href="/research/">
          <span class="feature-num">03</span><span><strong>Reading interfaces as arguments</strong><small>Research &middot; 11 min read</small></span><span class="arrow">-&gt;</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>