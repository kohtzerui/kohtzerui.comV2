---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="A quiet portfolio for research, writing, and work in progress.">
  <main>
    <section class="hero wrap">
      <div class="hero-copy reveal">
        <p class="eyebrow">Researcher · Builder · Note-taker</p>
        <h1>I make difficult ideas <em>easier to see.</em></h1>
        <p class="hero-lede">A calm corner of the internet for field notes, careful experiments, and things I have learned by building.</p>
        <div class="hero-actions">
          <a class="button button-dark" href="/blog/">Read the notes <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="/portfolio/">Explore selected work <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <aside class="desk-card reveal delay-1" aria-label="Currently exploring">
        <div class="desk-card-top"><span>DESK NOTE / 01</span><span class="status-dot">LIVE</span></div>
        <p class="handwritten">“Understanding begins when we give an idea somewhere to land.”</p>
        <svg class="orbit-sketch" viewBox="0 0 360 170" role="img" aria-label="A hand-drawn map connecting questions, systems, and stories">
          <path d="M42 89 C96 18 239 12 316 78 C265 154 107 160 42 89Z"/>
          <path d="M68 47 C110 118 243 135 297 50"/>
          <circle cx="71" cy="87" r="27"/><circle cx="181" cy="61" r="34"/><circle cx="284" cy="94" r="31"/>
          <text x="48" y="91">ask</text><text x="156" y="65">make</text><text x="260" y="98">learn</text>
        </svg>
        <div class="desk-tags"><span>AI systems</span><span>Human factors</span><span>Learning</span></div>
      </aside>
    </section>

    <section class="signal-strip" aria-label="Current status">
      <div class="wrap signal-inner">
        <p><span class="signal-label">NOW</span> Exploring how visual notes improve technical understanding.</p>
        <p class="signal-meta">Singapore · 1°17'N</p>
      </div>
    </section>

    <section class="wrap section-grid">
      <div>
        <p class="eyebrow">From the notebook</p>
        <h2>Recent thinking</h2>
      </div>
      <div class="feature-list">
        <a class="feature-row" href="/blog/ai-inference/">
          <span class="feature-num">01</span><span><strong>AI Inference: What happens after the model is trained?</strong><small>Foundational · 10 min read</small></span><span class="arrow">↗</span>
        </a>
        <a class="feature-row" href="/blog/model-evaluation/">
          <span class="feature-num">02</span><span><strong>Evaluating AI without fooling ourselves</strong><small>Systems · 8 min read</small></span><span class="arrow">↗</span>
        </a>
        <a class="feature-row" href="/research/">
          <span class="feature-num">03</span><span><strong>Reading interfaces as arguments</strong><small>Research · 11 min read</small></span><span class="arrow">↗</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>